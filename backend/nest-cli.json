{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "acu-solver/**/*.cjs", "outDir": "dist" },
      { "include": "acu-solver/**/*.json", "outDir": "dist" },
      { "include": "ml/**/*.json", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}