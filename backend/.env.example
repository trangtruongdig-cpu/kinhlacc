# Server
APP_PORT=3001
FRONTEND_URL=http://103.57.221.26:3000

# Database (PostgreSQL)
DB_HOST=your-db-host.com
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
CA_CERTIFICATE="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
FIREBASE_SERVICE_ACCOUNT=


# Auth
JWT_SECRET=your-strong-secret-key-here

# AI (yescale — OpenAI-compatible gateway)
YESCALE_API_KEY=
YESCALE_BASE_URL=https://api.yescale.vip/v1
YESCALE_MODEL=deepseek-v3.2

# AI tìm ảnh huyệt (Google Programmable Search — Custom Search JSON API, searchType=image)
# GOOGLE_CSE_API_KEY: API key từ Google Cloud Console (bật "Custom Search API")
# GOOGLE_CSE_CX:      mã "Search engine ID" của Programmable Search Engine (bật Image search + Search entire web)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Google Search Console (module SEO → tab GSC). Hướng dẫn từng bước: backend/GSC-SETUP.md
# CÁCH DỄ NHẤT: bỏ file khoá .json vào  backend/config/gsc-service-account.json  (không cần điền gì dưới đây).
# Hoặc chọn 1 trong các cách thay thế:
#   GSC_SERVICE_ACCOUNT_FILE=config/ten-file-khoa.json   (trỏ tới file .json bạn đã tải)
#   GSC_SERVICE_ACCOUNT={...}                            (dán NGUYÊN văn JSON, 1 dòng)
#   (bỏ trống tất cả = tái dùng FIREBASE_SERVICE_ACCOUNT)
# GSC_SITE_URL: property KHỚP ĐÚNG trong Search Console.
#   - URL-prefix property: https://kinhlac.online/     (property hiện tại của kinhlac — nhớ dấu "/" cuối)
#   - Domain property:     sc-domain:kinhlac.online    (nếu sau này đổi sang kiểu Domain)
GSC_SERVICE_ACCOUNT=
GSC_SERVICE_ACCOUNT_FILE=
GSC_SITE_URL=https://kinhlac.online/
#
# CÁCH OAuth (KHUYẾN NGHỊ khi không thêm được service account vào Search Console):
# đăng nhập trực tiếp bằng tài khoản CHỦ SỞ HỮU property (đã có sẵn quyền). Nếu 3 biến dưới
# có đủ, code sẽ DÙNG OAuth thay cho service account.
#   1. Tạo OAuth Client ID kiểu "Desktop app" trong Google Cloud (dự án kinhlac) → lấy ID + Secret.
#   2. Điền 2 dòng đầu, rồi chạy:  node tmp/gsc-oauth.mjs  → nó in ra GSC_OAUTH_REFRESH_TOKEN để dán nốt.
# Chi tiết: backend/GSC-SETUP.md (mục "OAuth").
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_OAUTH_REFRESH_TOKEN=

# IndexNow — báo Bing / Cốc Cốc / Yandex / Seznam / Naver index gần như tức thì khi đăng bài.
# (Google KHÔNG dùng IndexNow — đi qua sitemap + GSC. Cốc Cốc CÓ → quan trọng cho tìm kiếm tại VN.)
# Thiếu INDEXNOW_KEY → backend bỏ qua êm; radar SEO báo "Chưa cấu hình INDEXNOW_KEY ở backend (.env)".
#   INDEXNOW_KEY: chuỗi hex (>=16 ký tự). BẮT BUỘC có file  frontend/public/<key>.txt  (nội dung = đúng key)
#                 đã deploy, để search engine xác minh quyền sở hữu (keyLocation = SITE_DOMAIN/<key>.txt).
#                 Khoá đang dùng: 3ca42ea20a96a20d494868c1877e263c (file public/3ca42ea20a96a20d494868c1877e263c.txt đã có).
#   SITE_DOMAIN:  domain thật để dựng URL + keyLocation (mặc định https://kinhlac.online).
SITE_DOMAIN=https://kinhlac.online
INDEXNOW_KEY=3ca42ea20a96a20d494868c1877e263c

# AI SINH ẢNH minh hoạ thân bài blog (module SEO → nút "Sinh ảnh minh hoạ").
# Chọn 1 trong các cách (đều có lựa chọn MIỄN PHÍ — cần 1 key free):
#
# (A) Together.ai — KHUYẾN NGHỊ: 1 key, model FLUX miễn phí, OpenAI-compatible.
#   IMAGE_PROVIDER=together
#   IMAGE_API_BASE=https://api.together.xyz/v1
#   IMAGE_API_KEY=<key từ together.ai>
#   IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free
#
# (B) Pollinations — free nhưng NAY cần token (đăng ký miễn phí ở auth.pollinations.ai):
#   IMAGE_PROVIDER=pollinations
#   POLLINATIONS_TOKEN=<token free>
#   POLLINATIONS_MODEL=flux        # hoặc 'turbo' cho nhanh
#
# (C) Trả phí qua Yescale/OpenAI (OpenAI-compatible /images/generations, kiểu ĐỒNG BỘ):
#   IMAGE_PROVIDER=openai
#   IMAGE_MODEL=<model OpenAI-compatible>          # khai báo RÕ; để trống = KHÔNG chạy nhánh đồng bộ
#
# (D) Yescale MEDIA dạng "task" (gpt-image-2…) — bất đồng bộ submit→poll→CDN. KHUYẾN NGHỊ.
#   - PHẢI dùng token có quyền model media (tạo token "Auto tuỳ chỉnh"/"Thủ công" gồm nhóm "task"),
#     KHÔNG dùng token "Tạo nhanh" (sẽ báo "not available in any configured auto group").
#   - Đặt token đó vào IMAGE_API_KEY (text vẫn dùng YESCALE_API_KEY cũ).
#   - Liệt kê NHIỀU model, code thử lần lượt: model bận/lỗi nhảy sang model kế. Endpoint task tự bỏ /v1.
#   IMAGE_API_KEY=<token-media-Yescale>             # token nhóm "task" (KHÔNG phải token text cũ)
#   YESCALE_TASK_MODELS=gpt-image-2,gpt-image-1.5,gpt-image   # thử lần lượt (gpt-image-1 token KHÔNG có quyền)
#   YESCALE_TASK_QUALITY=medium                     # low|medium|high (BẮT BUỘC)
#   YESCALE_TASK_BACKGROUND=opaque                  # opaque|transparent|auto (gpt-image-1.5/gpt-image BẮT BUỘC)
#   IMAGE_SIZE=1024x1024                            # bội số 16, tổng điểm ảnh 655.360–8.294.400, cạnh dài ≤3840
#   YESCALE_TASK_BASE_URL=https://api.yescale.vip   # tuỳ chọn; mặc định = YESCALE_BASE_URL bỏ /v1
#   YESCALE_TASK_TIMEOUT_MS=180000                  # tuỳ chọn; chờ tối đa 1 ảnh (gpt-image-2 ~90s)
IMAGE_PROVIDER=pollinations
IMAGE_API_BASE=
IMAGE_API_KEY=
IMAGE_MODEL=
YESCALE_TASK_MODELS=
POLLINATIONS_TOKEN=

# Python ML Service (tongue CNN)
ML_SERVICE_URL=http://ml-service:3002
