{
  "_doc": "Bộ TỪ VỰNG phân loại ĐẶC TÍNH huyệt (controlled vocabulary). Mỗi 'trait' = 1 loại huyệt sẽ trở thành 1 mục tra cứu gom huyệt. 'any' = danh sách biểu thức (regex) khớp trên text ĐẶC TÍNH, KHÔNG phân biệt hoa/thường, CÓ phân biệt dấu tiếng Việt. Khớp 1 cái bất kỳ là gắn nhãn (1 huyệt có thể mang nhiều nhãn). Sửa file này thoải mái (thêm/bớt loại, chỉnh regex) rồi chạy lại: node _build-dict.cjs",
  "traits": [
    { "id": "ky-huyet",   "ten": "Kỳ Huyệt",                "nhom": "Loại Huyệt", "moTa": "Huyệt ngoài 12 chính kinh và 8 mạch (huyệt ngoài kinh).", "any": ["kỳ huyệt"] },
    { "id": "huyet-moi",  "ten": "Huyệt Mới",               "nhom": "Loại Huyệt", "moTa": "Huyệt được phát hiện/đặt tên thời hiện đại.",            "any": ["huyệt mới"] },
    { "id": "chinh-kinh", "ten": "Huyệt Chính Kinh / Mạch", "nhom": "Loại Huyệt", "moTa": "Huyệt nằm trên 12 chính kinh hoặc mạch Nhâm/Đốc.",       "any": ["huyệt thứ \\d+ của (kinh|mạch)"] },

    { "id": "nd-tinh", "ten": "Tỉnh Huyệt",         "nhom": "Ngũ Du Huyệt", "any": ["huyệt tỉnh\\b"] },
    { "id": "nd-vinh", "ten": "Vinh Huyệt",         "nhom": "Ngũ Du Huyệt", "any": ["huyệt vinh\\b"] },
    { "id": "nd-du",   "ten": "Du Huyệt (Ngũ Du)",  "nhom": "Ngũ Du Huyệt", "any": ["huyệt du\\b"] },
    { "id": "nd-kinh", "ten": "Kinh Huyệt (Ngũ Du)","nhom": "Ngũ Du Huyệt", "any": ["huyệt kinh\\b(?! mạch)"] },
    { "id": "nd-hop",  "ten": "Hợp Huyệt",          "nhom": "Ngũ Du Huyệt", "any": ["huyệt hợp\\b"] },

