    { "id": "dd-lac",     "ten": "Lạc Huyệt",           "nhom": "Huyệt Đặc Dụng", "any": ["huyệt lạc"] },
    { "id": "dd-khich",   "ten": "Khích Huyệt",         "nhom": "Huyệt Đặc Dụng", "any": ["huyệt khích"] },
    { "id": "dd-mo",      "ten": "Mộ Huyệt",            "nhom": "Huyệt Đặc Dụng", "any": ["huyệt mộ"] },
    { "id": "dd-hoi",     "ten": "Bát Hội Huyệt",       "nhom": "Huyệt Đặc Dụng", "moTa": "Hội của Tạng/Phủ/Khí/Huyết/Cân/Mạch/Cốt/Tủy.", "any": ["huyệt hội của (tạng|phủ|khí|huyết|cân|mạch|cốt|tủy)"] },
    { "id": "dd-giaohoi", "ten": "Giao Hội Huyệt",      "nhom": "Huyệt Đặc Dụng", "moTa": "Huyệt nơi nhiều kinh/mạch gặp nhau.", "any": ["giao hội", "hội của mạch"] },
