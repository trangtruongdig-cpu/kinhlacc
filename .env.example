# ============================================================
#  Biến cho docker-compose (KHÔNG phải biến runtime của Nest).
#  Copy file này sang `.env` cùng cấp với docker-compose.yml:
#     cp .env.example .env
#  Toàn bộ thông tin database Aiven nằm trong `backend/.env`, không phải file này.
# ============================================================

# ---- Cổng HTTP frontend mở ra Internet trên VPS ----
# Khi đã có reverse proxy (Caddy / nginx-proxy / Traefik) trước docker,
# có thể đổi sang 8080 và để proxy trỏ vào.
HTTP_PORT=80

# ---- URL API mà bundle Vite sẽ gọi ----
# Để "/api" => nginx của container frontend tự proxy sang backend:3001
# (an toàn, same-origin, không cần CORS).
# Chỉ đổi thành URL tuyệt đối nếu frontend và backend chạy ở 2 domain khác nhau.
VITE_API_URL=/api
